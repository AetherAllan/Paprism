{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "buildArtifactPaths": ["android/app/build/outputs/apk/release/*.apk"],
      "android": {
        "gradleCommand": ":app:assembleRelease",
        "applicationArchivePath": "android/app/build/outputs/apk/release/app-universal-release.apk",
        "autoIncrement": true
      }
    }
  }
}
