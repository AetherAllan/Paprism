{
  "expo": {
    "name": "Paprism",
    "slug": "paprism",
    "orientation": "portrait",
    "icon": "./assets/AndroidLogo.png",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.paprism.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/AndroidLogo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/AndroidLogo.png"
    },
    "plugins": [
      "expo-localization",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/AndroidLogo.png",
          "backgroundColor": "#000000",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "react-native-enriched-markdown",
        {
          "enableMath": true
        }
      ],
      "./plugins/withAbiSplits"
    ],
    "owner": "dudeguuuds-organization",
    "extra": {
      "eas": {
        "projectId": "79f70aa5-de06-4c9c-8e9d-4c925a23e4ab"
      }
    }
  }
}
